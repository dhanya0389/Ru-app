# Ruhi env vars. Copy this file to .env.local for local dev. On Vercel,
# set each one in Project Settings → Environment Variables.

# ── Anthropic (existing) ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── USDA FoodData Central (existing) ──────────────────────────────
# https://fdc.nal.usda.gov/api-key-signup.html — free public API key
USDA_API_KEY=

# ── Auth.js / next-auth v5 (PR #25) ───────────────────────────────
# AUTH_SECRET: random 32-byte secret for signing JWT session cookies.
#   Generate locally with:  openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client credentials. See docs/auth-setup.md for the GCP
# console walkthrough. Authorized redirect URIs to register there:
#   http://localhost:3000/api/auth/callback/google     (dev)
#   https://tryruhi.ai/api/auth/callback/google        (prod)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional in prod (Vercel auto-sets it). Forces Auth.js to trust the
# host header — needed when running behind a proxy / preview deploy.
# AUTH_TRUST_HOST=true
