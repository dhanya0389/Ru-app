# Ruhi env vars. Copy this file to .env.local for local dev. On Vercel,
# set each one in Project Settings → Environment Variables.

# ── Anthropic (existing) ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── USDA FoodData Central (existing) ──────────────────────────────
# https://fdc.nal.usda.gov/api-key-signup.html — free public API key
USDA_API_KEY=

# ── Supabase (PR #28 onward) ──────────────────────────────────────
# Project URL and Publishable (anon) key from your Supabase project.
# Found in Supabase dashboard:
#   URL  → Settings → Data API (or General) → "Project URL"
#   Key  → Settings → API Keys → "Publishable key" (starts with sb_publishable_…)
# Both are public-safe — Row Level Security gates actual data access.
# See docs/supabase-setup.md for the one-time project provisioning walkthrough.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth credentials (used by Supabase Auth's Google provider).
# These are configured INSIDE the Supabase dashboard, not here:
#   Supabase → Authentication → Providers → Google → paste Client ID + Secret
# See docs/auth-setup.md for the one-time Google Cloud Console setup.
# (No env vars needed in this file — Supabase stores them server-side.)
